<UserControl x:Class="ClientVodenko.Views.VodenkoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientVodenko.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>

        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavBtnActive" TargetType="Button" BasedOn="{StaticResource NavBtn}">
            <Setter Property="Background" Value="#00BFFF"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="FieldInput" TargetType="TextBox">
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#00BFFF"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#2E2E2E" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="350"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="70" Height="70" Margin="0,0,10,0"
                           Source="C:\Users\Luka\Documents\Vodenko\ClientVodenko\images\danieliLogo.jpg"/>
                    <Image Width="70" Height="70" Margin="0,0,15,0"
                           Source="C:\Users\Luka\Documents\Vodenko\ClientVodenko\images\mathosLogo.png"/>
                    <TextBlock Text="EAF CONTROL" Foreground="White"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Margin="20,0">
                        <Ellipse x:Name="LedPlc" Width="14" Height="14" Fill="#F44336"/>
                        <TextBlock Text="PLC" Foreground="#CFCFCF" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="20,0">
                        <Ellipse x:Name="LedBackend" Width="14" Height="14" Fill="#4CAF50"/>
                        <TextBlock Text="BACKEND" Foreground="#CFCFCF" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="20,0">
                        <Ellipse x:Name="LedDatabase" Width="14" Height="14" Fill="#FF9800"/>
                        <TextBlock Text="DATABASE" Foreground="#CFCFCF" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2" Background="#222222" CornerRadius="6"
                        Padding="10" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock x:Name="PlcAddressText"
                                   Text="192.168.0.1 | Rack 0 | Slot 1"
                                   Foreground="#DDDDDD" FontSize="12"/>
                        <TextBlock x:Name="CpuText" Text="CPU: S7-1500" Foreground="#00BFFF"
                                   FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#151515" BorderBrush="#2E2E2E" BorderThickness="0,0,1,0">
                <StackPanel Margin="10">
                    <Button x:Name="ProcessBtn"    Content="PROCESS VIEW" Click="ProcessBtn_Click"    Style="{StaticResource NavBtnActive}"/>
                    <Button x:Name="ConnectionBtn" Content="CONNECTION"   Click="ConnectionBtn_Click" Style="{StaticResource NavBtn}"/>
                    <Button x:Name="HistoryBtn"    Content="HISTORY"      Click="HistoryBtn_Click"    Style="{StaticResource NavBtn}"/>
                    <Button x:Name="AlarmsBtn"     Content="ALARMS"       Click="AlarmsBtn_Click"     Style="{StaticResource NavBtn}"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1">


                <!-- PROCESS VIEW !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! -->


                <Grid x:Name="ProcessPage" Visibility="Visible" Background="#101010">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="120"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- VRIJEDNOSTI -->

                        <UniformGrid Columns="2" Margin="12,10">
                            <Border Margin="5" Background="#1E1E1E" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="ACTUAL LEVEL"     Foreground="#777" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ActualLevel" Text="0.0" Foreground="#00E5A0" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="%"           Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="5" Background="#1E1E1E" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="VALVE POSITION"      Foreground="#777" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="ValvePosition" Text="0.0" Foreground="#E88080" FontSize="26" FontWeight="Bold"/>
                                    <TextBlock Text="%"           Foreground="#666" FontSize="11"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>

                        <!-- FURNACE CANVAS -->
                        <StackPanel>
                            <Border x:Name="OverfillBanner" Background="Red" Visibility="Collapsed">
                                <TextBlock Text="ALARM: Tank Overfill!" Foreground="White" HorizontalAlignment="Center"/>
                            </Border>

                            <Border x:Name="InvalidSetpointBanner" Background="Orange" Visibility="Collapsed">
                                <TextBlock Text="WARNING: Invalid Setpoint!" Foreground="White" HorizontalAlignment="Center"/>
                            </Border>

                            <Border x:Name="InvalidValveBanner" Background="Orange" Visibility="Collapsed">
                                <TextBlock Text="WARNING: Manual Valve Invalid!" Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <Border Grid.Row="1" Background="#111111" Margin="12,0,12,12" CornerRadius="6">
                            <Viewbox Stretch="Uniform">
                                <Grid Width="560" Height="360">

                                    <Canvas Width="560" Height="360">

                                        <Rectangle Canvas.Left="105" Canvas.Top="20" Width="60" Height="20" Fill="#444444" Stroke="#666666" StrokeThickness="1.5"/>

                                        


                                        <Rectangle Canvas.Left="130" Canvas.Top="80" Width="300" Height="220" Fill="#1A1A1A"/>

                                        <Path Stroke="#888888" StrokeThickness="4" Fill="Transparent">
                                            <Path.Data>
                                                <PathGeometry>
                                                    <PathFigure StartPoint="130,80">
                                                        <LineSegment Point="130,300"/>
                                                        <LineSegment Point="430,300"/>
                                                        <LineSegment Point="430,80"/>
                                                    </PathFigure>
                                                </PathGeometry>
                                            </Path.Data>
                                        </Path>

                                        <Rectangle x:Name="WaterFill" 
               Canvas.Left="132" Canvas.Top="200" 
               Width="296" Height="100" 
               Fill="#00BFFF" />


                                        <TextBlock x:Name="WaterLevelText"
               Canvas.Left="265" Canvas.Top="170"
               Text="45%"
               Foreground="#00BFFF" FontSize="16" FontWeight="Bold"/>


                                        <Rectangle Canvas.Left="430" Canvas.Top="275" Width="40" Height="20" Fill="#444444" Stroke="#666666" StrokeThickness="1.5"/>

                                        <Rectangle x:Name="ValveGate" 
               Canvas.Left="432" Canvas.Top="255" 
               Width="8" Height="22" 
               Fill="#FF4500" Stroke="#CC3300" StrokeThickness="1"/>

                                        <Path x:Name="OutflowStream" Fill="#00BFFF" Opacity="0.8">
                                            <Path.Data>
                                                <PathGeometry>
                                                    <PathFigure StartPoint="470,277" IsClosed="True">
                                                        <LineSegment Point="540,310"/>
                                                        <LineSegment Point="540,322"/>
                                                        <LineSegment Point="470,293"/>
                                                    </PathFigure>
                                                </PathGeometry>
                                            </Path.Data>
                                        </Path>
                                        <Rectangle x:Name="InflowStream" 
                                        Canvas.Left="135" Canvas.Top="40" 
                                        Width="14" Height="258" 
                                        Fill="#00BFFF" />
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Border>
                    </Grid>


                    <!-- PROCESS CONTROL -->


                    <Border Grid.Column="1" Background="#181818"
                            BorderBrush="#2E2E2E" BorderThickness="1,0,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="18,20">

                                <TextBlock Text="PROCESS CONTROL" Foreground="White"
                                           FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Ellipse x:Name="LedSetpoint" Width="11" Height="11"
                                            Fill="#444444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="SETPOINT INVALID" Foreground="#AAA"
                                            FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                                        <Ellipse x:Name="LedOverfill" Width="11" Height="11"
                                            Fill="#444444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="TANK OVERFILL" Foreground="#AAA"
                                            FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>


                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal">
                                        <Ellipse x:Name="LedValve" Width="11" Height="11"
                                            Fill="#444444" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="MANUAL VALVE INVALID" Foreground="#AAA"
                                            FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="LEVEL SETPOINT (%)" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24*"/>
                                        <ColumnDefinition Width="19*"/>
                                        <ColumnDefinition Width="146*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LevelSetpointInput" Text="0"
                                             Style="{StaticResource FieldInput}" Grid.ColumnSpan="3"/>
                                    <Button x:Name="SetLevelBtn" Grid.Column="3"
                                            Content="SET"
                                            Height="38"
                                            Background="#00BFFF" Foreground="White"
                                            FontWeight="Bold" FontSize="12"
                                            BorderBrush="{x:Null}"
                                            Click="SetLevelBtn_Click" Grid.ColumnSpan="2" Margin="8,-1,0,12"/>
                                </Grid>

                                <TextBlock Text="VALVE POSITION  (0% – 100%)" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="46"/>
                                    </Grid.ColumnDefinitions>
                                    <Slider x:Name="ValveSlider" Minimum="0" Maximum="15"
                                            Value="0" Foreground="#00E5A0"
                                            VerticalAlignment="Center"
                                            ValueChanged="ValveSlider_ValueChanged"/>
                                    <TextBlock x:Name="TapAngleLabel" Grid.Column="1"
                                               Text="0.0%" Foreground="#00E5A0"
                                               FontSize="12" VerticalAlignment="Center"
                                               HorizontalAlignment="Right"/>
                                </Grid>

                                <Separator Background="#2E2E2E" Margin="0,0,0,0"/>

                                <Border x:Name="EmptyBanner" Visibility="Collapsed"
                                        Background="#1A2A1A" CornerRadius="4"
                                        Padding="10,6" Margin="0,0,0,12">
                                    <TextBlock Text="FURNACE EMPTY — ready for charging"
                                               Foreground="#4CAF50" FontSize="12" FontWeight="SemiBold"/>
                                </Border>

                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                </Grid>

                                <Button Content="START"                                  
                                Style="{StaticResource ActionBtn}"
                                Background="#45AB26"
                                Margin="0,0,0,16"
                                />

                                <Button Content="RESET" Click="ResetBtn_Click"                                       
                                        Style="{StaticResource ActionBtn}"
                                        Background="#7A1A1A"
                                        Margin="0"
                                        />

                                

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>


                <!-- CONNECTION !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! -->


                <Grid x:Name="ConnectionPage" Visibility="Collapsed" Background="#101010">
                    <ScrollViewer>
                        <StackPanel Margin="25">
                            <TextBlock Text="PLC CONNECTION" Foreground="White"
                                       FontSize="24" FontWeight="Bold" Margin="0,0,0,25"/>
                            <Border Background="#1E1E1E" CornerRadius="8" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="IP ADDRESS" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="IpInput" Text=""
                                             Background="#2A2A2A" Foreground="#00BFFF"
                                             BorderBrush="#333" Padding="10,8"
                                             FontSize="14" Margin="0,0,0,16"/>

                                    <TextBlock Text="RACK" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="RackInput"  Text=""
                                             Background="#2A2A2A" Foreground="#00BFFF"
                                             BorderBrush="#333" Padding="10,8"
                                             FontSize="14" Margin="0,0,0,16"/>

                                    <TextBlock Text="SLOT" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <TextBox x:Name="SlotInput"  Text=""
                                             Background="#2A2A2A" Foreground="#00BFFF"
                                             BorderBrush="#333" Padding="10,8"
                                             FontSize="14" Margin="0,0,0,24"/>

                                    <TextBlock Text="CPU TYPE" Foreground="#AAA" FontSize="11" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="CpuTypeInput"
                                              Background="#2A2A2A" Foreground="Black"
                                              BorderBrush="#333" Padding="10,8"
                                              FontSize="14" Margin="0,0,0,24"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="S7-1500"/>
                                        <ComboBoxItem Content="S7-1200"/>
                                        <ComboBoxItem Content="S7-400"/>
                                        <ComboBoxItem Content="S7-300"/>
                                    </ComboBox>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="ConnectBtn" Grid.Column="0"
                                            Content="CONNECT" Height="44"
                                                Background="#1F5F2C" Foreground="White"
                                                FontWeight="Bold" BorderBrush="{x:Null}"
                                                Click="ConnectBtn_Click"
                                                />
                                        <Button x:Name="DisconnectBtn" Grid.Column="2" Content="DISCONNECT" Height="44"
                                                Background="#7A1A1A" Foreground="White"
                                                FontWeight="Bold" BorderBrush="{x:Null}"
                                                Click="DisconnectBtn_Click"
                                                />
                                    </Grid>

                                    <Border Margin="0,20,0,0" Background="#111111"
                                            CornerRadius="4" Padding="12,8">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse x:Name="ConnStatusLed" Width="12" Height="12"
                                                     Fill="#F44336" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <TextBlock x:Name="ConnStatusText" Text="Not connected"
                                                       Foreground="#CCC" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>


                <!-- HISTORY !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! -->


                <Grid x:Name="HistoryPage" Visibility="Collapsed" Background="#101010">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="EVENT HISTORY" Foreground="White"
                                        FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>

                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
                            <Border Margin="0,0,8,0" Background="#1E1E1E" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="TOTAL EVENTS" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="HistTotalEvents" Text="0" Foreground="#00BFFF"
                                                FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4,0" Background="#1E1E1E" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="ALARMS" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="HistAlarmCount" Text="0" Foreground="#FF4444"
                               FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>

                        <DataGrid x:Name="HistoryGrid" Grid.Row="2"
                                  ItemsSource="{Binding Events}"
                                  Background="#1E1E1E" Foreground="White"
                                  BorderBrush="#333" RowBackground="#1E1E1E"
                                  AlternatingRowBackground="#242424"
                                  HeadersVisibility="Column" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#2E2E2E"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2A2A2A"/>
                                    <Setter Property="Foreground" Value="#AAAAAA"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAlarm}" Value="True">
                                            <Setter Property="Foreground" Value="#FF8888"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NAME" Width="170"
                                    Binding="{Binding Name, StringFormat=dd.MM.yyyy HH:mm:ss}"/>
                                <DataGridTextColumn Header="TYPE" Width="100"
                                    Binding="{Binding Type}"/>
                                <DataGridTextColumn Header="TIME" Width="*"
                                    Binding="{Binding Time}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>


                <!-- ALARMS !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!! -->


                <Grid x:Name="AlarmsPage" Visibility="Collapsed" Background="#101010">
                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ACTIVE ALARMS" Foreground="White"
                                            FontSize="24" FontWeight="Bold"/>
                                <Border x:Name="AlarmCountBadge"
                                        Background="#CC2222" CornerRadius="10"
                                        Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="AlarmCountText" Text="0"
                                                Foreground="White" FontSize="12" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <Button x:Name="AckAllBtn" Grid.Column="1"
                                    Content="ACK ALL" Height="34" Padding="16,0"
                                    Background="#7A1A1A" Foreground="White"
                                    FontWeight="Bold" FontSize="11" BorderBrush="{x:Null}"
                                    />
                        </Grid>

                        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,16">
                            <Border Margin="0,0,8,0" Background="#2A0A0A" BorderBrush="#CC2222"
                                    BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="OVERFILL" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <Ellipse x:Name="AlarmLedOverfill" Width="14" Height="14"
                                            Fill="#444444" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="4,0" Background="#2A0A0A" BorderBrush="#CC2222"
                                        BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="OVERTEMPERATURE" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <Ellipse x:Name="AlarmLedOvertemp" Width="14" Height="14"
                                             Fill="#444444" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="8,0,0,0" Background="#2A0A0A" BorderBrush="#CC2222"
                                    BorderThickness="0,0,0,2" CornerRadius="6" Padding="14,10">
                                <StackPanel>
                                    <TextBlock Text="TAPPING ERROR" Foreground="#777" FontSize="10" FontWeight="SemiBold"/>
                                    <Ellipse x:Name="AlarmLedTapError" Width="14" Height="14"
                                                Fill="#444444" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <DataGrid x:Name="AlarmGrid" Grid.Row="2"
                                  Background="#1E1E1E" Foreground="White"
                                  BorderBrush="#333" RowBackground="#1E1E1E"
                                  AlternatingRowBackground="#2A0A0A"
                                  HeadersVisibility="Column" AutoGenerateColumns="False"
                                  IsReadOnly="True" CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#2E2E2E"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#2A2A2A"/>
                                    <Setter Property="Foreground" Value="#AAAAAA"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="TIME" Width="170"
                                    Binding="{Binding Timestamp, StringFormat=dd.MM.yyyy HH:mm:ss}"/>
                                <DataGridTextColumn Header="ALARM" Width="200"
                                    Binding="{Binding AlarmName}"/>
                                <DataGridTextColumn Header="DESCRIPTION" Width="*"
                                    Binding="{Binding Description}"/>
                                <DataGridTextColumn Header="STATUS" Width="110"
                                    Binding="{Binding Status}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>


            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="#1A1A1A"
                BorderBrush="#2E2E2E"
                BorderThickness="0,1,0,0">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="{Binding LastEventTime}"
                               Foreground="#FF9800"
                               FontSize="12"/>

                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding LastEventText}"
                           Foreground="#DDDDDD"
                           FontSize="15"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <ToggleButton Width="120" Height="36" Margin="0,0,20,0" x:Name="ModeToggle">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Grid Background="Transparent" Cursor="Hand">
                                    <Border x:Name="BackgroundBorder" 
                        Background="#444444" 
                        CornerRadius="18">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="MAN" 
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="11"/>

                                            <TextBlock Grid.Column="1" 
                                   Text="AUTO" 
                                   Foreground="White" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"
                                   FontSize="11"/>
                                        </Grid>
                                    </Border>

                                    <Border x:Name="SliderCircle" 
                        Width="56" 
                        Height="32" 
                        Background="White" 
                        CornerRadius="16" 
                        HorizontalAlignment="Left" 
                        Margin="2,0,2,0">
                                        <TextBlock x:Name="SliderText"
                               Text="MANUAL" 
                               Foreground="#444444" 
                               FontWeight="Bold"
                               FontSize="10"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="BackgroundBorder" Property="Background" Value="#00BFFF"/>
                                        <Setter TargetName="SliderCircle" Property="HorizontalAlignment" Value="Right"/>
                                        <Setter TargetName="SliderText" Property="Text" Value="AUTO"/>
                                        <Setter TargetName="SliderText" Property="Foreground" Value="#00BFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock HorizontalAlignment="Right" 
                                   x:Name="CurrentTimeText"
                                   Text="14:22:05"
                                   Foreground="#DDDDDD"
                                   FontSize="12"/>
                        <TextBlock x:Name="CurrentDateText"
                                   Text="18.05.2026"
                                   Foreground="#DDDDDD"
                                   FontSize="12"/>
                    </StackPanel>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</UserControl>
